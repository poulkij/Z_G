# 数据模式: jnb(走Tushare API) 或 websearch(走网络搜索)
DATA_MODE=jnb

# Tushare API 配置
# 注意：以下两项仅在 DATA_MODE=jnb 时必须填写
TUSHARE_TOKEN=你...n
# Tushare 中转 API 地址（必填，如果使用 websearch 模式则忽略）
# 格式: http://your-proxy-server.com
# 示例: https://tt.xiaodefa.cn
TUSHARE_API_URL=
# TUSHARE_VERIFY_TOKEN_URL=*** 可选，实时行情验证地址

# 数据库配置
DATA_DIR=data
DB_PATH=data/stock_data.db

# LLM 配置（意图识别后的回答生成，可选）
# 未配置 LLM_API_KEY 时不生成回答，仅显示意图识别结果
# 支持 OpenAI 兼容格式的 API
LLM_API_KEY=*** LLM_...n
# 向量知识库配置（可选，默认关闭）
# KB_ENABLED=true  # 取消注释以启用
# KB_API_URL=http://localhost:8000
